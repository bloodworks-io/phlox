{
    "name": "Phlox",
    "version": "1.0.5",
    "private": true,
    "dependencies": {
        "@chakra-ui/react": "^3.36.0",
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "11.14.1",
        "@tauri-apps/api": "2.10.1",
        "@tauri-apps/plugin-http": "2.5.7",
        "framer-motion": "11.18.2",
        "js-tiktoken": "1.0.21",
        "pdf-lib": "^1.17.1",
        "pdfjs-dist": "4.10.38",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-icons": "5.6.0",
        "react-markdown": "8.0.7",
        "react-router-dom": "6.30.4",
        "react-textarea-autosize": "8.5.9",
        "remark-gfm": "^3.0.1"
    },
    "scripts": {
        "start-react": "vite",
        "dev": "parallel --tag --line-buffer ::: \"npm run start-react\" \"uvicorn server.server:app --reload --host 0.0.0.0 --port 6000\"",
        "build": "vite build",
        "typecheck": "tsc --noEmit",
        "build-server": "bash src-tauri/build-server.sh",
        "test": "vitest",
        "tauri": "tauri",
        "tauri-dev": "bash build-all.sh --debug --skip-cpp && tauri dev",
        "tauri-build": "bash build-all.sh && tauri build"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "description": "Open-source patient management with AI-powered transcription and clinical notes.",
    "main": "index.js",
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@tauri-apps/cli": "2.10.1",
        "@types/node": "^25.9.3",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "4.7.0",
        "typescript": "^6.0.3",
        "vite": "7.3.5"
    }
}
