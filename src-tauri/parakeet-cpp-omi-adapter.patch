+// --- Long-audio chunking + merge helpers (ported from omi-med-stt-runtime)
+std::string normalize_ws(const std::string& s) {
+    std::string out;
+    out.reserve(s.size());
+    bool in_ws = true;  // suppresses leading spaces
+    for (unsigned char c : s) {
+        if (c == ' ' || c == '\t' || c == '\n' || c == '\r' || c == '\v' || c == '\f') {
+            if (!in_ws) { out.push_back(' '); in_ws = true; }
+        } else {
+            out.push_back((char)c);
+            in_ws = false;
+        }
+    }
+    if (!out.empty() && out.back() == ' ') out.pop_back();
+    return out;
+}
+
+std::vector<std::string> split_words(const std::string& s) {
+    std::vector<std::string> words;
+    std::string cur;
+    for (unsigned char c : s) {
+        if (c == ' ' || c == '\t' || c == '\n' || c == '\r') {
+            if (!cur.empty()) { words.push_back(cur); cur.clear(); }
+        } else {
+            cur.push_back((char)c);
+        }
+    }
+    if (!cur.empty()) words.push_back(cur);
+    return words;
+}
+
+std::string to_lower_word(const std::string& s) {
+    std::string o = s;
+    for (auto& c : o) c = (char)std::tolower((unsigned char)c);
+    return o;
+}
+
+std::string merge_overlap(const std::string& existing_in, const std::string& addition_in,
+                          size_t* overlap_words, size_t max_overlap_words = 80) {
+    if (overlap_words) *overlap_words = 0;
+    std::string existing = normalize_ws(existing_in);
+    std::string addition = normalize_ws(addition_in);
+    if (existing.empty()) return addition;
+    if (addition.empty()) return existing;
+
+    std::vector<std::string> a = split_words(existing);
+    std::vector<std::string> b = split_words(addition);
+    size_t max_n = std::min(std::min(max_overlap_words, a.size()), b.size());
+    for (size_t n = max_n; n >= 1; --n) {
+        bool match = true;
+        for (size_t i = 0; i < n; ++i) {
+            if (to_lower_word(a[a.size() - n + i]) != to_lower_word(b[i])) {
+                match = false;
+                break;
+            }
+        }
+        if (match) {
+            if (overlap_words) *overlap_words = n;
+            std::string out;
+            for (size_t i = 0; i < a.size(); ++i) { if (i) out += ' '; out += a[i]; }
+            for (size_t i = n; i < b.size(); ++i) { out += ' '; out += b[i]; }
+            return out;
+        }
+    }
+    return existing + " " + addition;
+}
